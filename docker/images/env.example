# NeoDev 内网部署环境变量
# 使用: 复制为 .env 后按需修改，再执行 docker compose up -d
#   cp env.example .env
#   vi .env

# ── LLM（必填：否则 Agent / AI 分析不可用）────────────────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL_CHAT=deepseek-v3.2
OPENAI_MODEL_EMBEDDING=text-embedding-v3

# ── 可选 ────────────────────────────────────────────────────────
# AI_ANALYSIS_MAX_WORKERS=5
